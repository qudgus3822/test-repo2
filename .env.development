# API Base URL - 상대 경로 사용 (Vite proxy 및 프록시 서버를 통해 백엔드로 라우팅됨)
VITE_API_BASE_URL=/api/v1  # 로컬 환경
#VITE_API_BASE_URL=https://dev-devmetrics-api.aws-bithumb.com/api/v1 # 개발 환경

# Environment
VITE_ENV=development

# Application
VITE_APP_NAME=BDPI Dashboard

# 인증 스킵 여부 (true: 로그인 없이 접근 가능, false: 로그인 필수)
VITE_SKIP_AUTH=false
